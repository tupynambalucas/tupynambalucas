{
  "files.exclude": {
    "**/.git": true,
    "**/.eslintcache": false,
    "**/node_modules": false,
    "**/dist": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.eslintcache": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.turbo/**": true
  },

  /* --- Schemas --- */

  /* --- JSON Schemas --- */
  "json.schemas": [
    {
      "fileMatch": ["package.json", "**/package.json"],
      "url": "./.vscode/schemas/schema-package.json"
    },
    {
      "fileMatch": ["tsconfig.json", "**/tsconfig.json", "**/tsconfig.*.json"],
      "url": "./.vscode/schemas/schema-tsconfig.json"
    },
    {
      "fileMatch": [".prettierrc", "**/prettierrc.json"],
      "url": "./.vscode/schemas/schema-prettierrc.json"
    },
    {
      "fileMatch": [".changeset/config.json"],
      "url": "./.vscode/schemas/schema-changesets.json"
    }
  ],

  /* --- YAML Schemas --- */
  "yaml.schemas": {
    ".vscode/schemas/schema-docker-compose.json": ["**/compose.yaml", "**/*compose*.yaml"],
    ".vscode/schemas/schema-pnpm-workspace.json": ["pnpm-workspace.yaml"]
  },

  /* --- Eslint Config --- */
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.options": {
    "cache": true,
    "cacheLocation": ".eslintcache"
  },
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.lintTask.enable": true,

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": false
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": false
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": false
  },

  "[mdx]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.wordWrap": "on"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on"
  },
  "[markdown_latex_combined]": {
    "editor.formatOnSave": true,
    "editor.wordWrap": "on"
  },

  /* --- Prettier Formatting --- */
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": true,
  "prettier.configPath": "shared/config/prettierrc.json",
  "prettier.ignorePath": "shared/config/.prettierignore",

  /* --- Tailwind CSS IntelliSense --- */
  "tailwindCSS.showPixelEquivalents": true,
  "tailwindCSS.classAttributes": ["class", "className", "classNames", "tw"],
  "tailwindCSS.lint.cssConflict": "warning",
  "tailwindCSS.lint.invalidApply": "error",
  "tailwindCSS.lint.invalidConfigPath": "error",
  "tailwindCSS.lint.invalidScreen": "error",
  "tailwindCSS.lint.invalidTailwindDirective": "error",
  "tailwindCSS.lint.invalidVariant": "error",
  "tailwindCSS.lint.recommendedVariantOrder": "warning",

  /* --- ESLint Probe Languages --- */
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "markdown"
  ],

  /* --- Material Icon Theme --- */
  "material-icon-theme.activeIconPack": "react",
  "material-icon-theme.folders.theme": "specific",

  /* --- YAML formatting --- */
  "yaml.format.enable": true,
  "yaml.format.singleQuote": false,
  "yaml.format.bracketSpacing": true,
  "yaml.format.proseWrap": "preserve",

  /* --- Markdown Preview Enhanced --- */
  "markdown-preview-enhanced.codeBlockTheme": "auto.css",
  "markdown-preview-enhanced.previewTheme": "github-light.css",
  "markdown-preview-enhanced.enableWikiLinkSyntax": true,

  /* --- TypeScript Core --- */
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.maxMemory": 4096,
  "js/ts.tsserver.log": "off",
  "js/ts.tsserver.automaticTypeAcquisition.enabled": false,

  /* --- IntelliSense & Auto Imports --- */
  "js/ts.suggest.autoImports": true,
  "js/ts.preferences.includePackageJsonAutoImports": "auto",
  "js/ts.updateImportsOnFileMove.enabled": "always",

  /* --- Performance vs Diagnostics --- */
  "js/ts.tsserver.experimental.enableProjectDiagnostics": false,

  /* --- Styles (TailwindCSS v4 compatibility) --- */
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,

  /* --- Misc --- */
  // "json.schemaDownload.enable": true,
  // "yaml.schemaStore.enable": true,
  // "yaml.kubernetesCRDStore.enable": false,

  /* --- Color Highlight --- */
  "color-highlight.languages": ["*", "!json", "!yaml", "!markdown", "!mdx"]

  /* --- GitHub Copilot Chat Configuration --- */
}
