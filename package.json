{
  "name": "@tupynambalucas",
  "private": true,
  "type": "module",
  "author": "Tupynambá Lucas Varela Rodrigues <tupynambalucas.dev>",
  "license": "CC-BY-NC-4.0",
  "homepage": "https://tupynambalucas.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tupynambalucas/tupynambalucas.git"
  },
  "packageManager": "pnpm@11.9.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0"
    }
  },
  "scripts": {
    "// Docs": "---------------------------------------------",
    "docs:typecheck": "pnpm --filter @tupynambalucas/docs typecheck",
    "docs:lint": "pnpm --filter @tupynambalucas/docs lint",
    "docs:generate:changelog": "pnpm --filter @tupynambalucas/docs docs:generate:changelog",
    "docs:generate:roadmap": "pnpm --filter @tupynambalucas/docs docs:generate:roadmap",
    "docs:dev": "pnpm --filter @tupynambalucas/docs start",
    "docs:dev:pt": "pnpm --filter @tupynambalucas/docs start:pt",
    "docs:build": "turbo run build --filter=@tupynambalucas/docs",
    "docs:preview": "pnpm docs:build && pnpm --filter @tupynambalucas/docs serve",
    "docs:clear": "pnpm --filter @tupynambalucas/docs clear",
    "docs:down": "pnpm dlx kill-port 3002",
    "// Hub": "---------------------------------------------",
    "hub:dev": "kill-port 3000 5173 && pnpm hub:up && turbo run dev --filter=@tupynambalucas-hub/*",
    "hub:build": "turbo run build --filter=@tupynambalucas-hub/*",
    "hub:lint": "turbo run lint --filter=@tupynambalucas-hub/*",
    "hub:typecheck": "turbo run typecheck --filter=@tupynambalucas-hub/*",
    "hub:up": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.override.yaml --env-file hub/infrastructure/docker/.env.dev --profile dev up -d --build",
    "hub:down": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.override.yaml --env-file hub/infrastructure/docker/.env.dev --profile dev down && kill-port 3000 5173",
    "hub:reset": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.override.yaml --env-file hub/infrastructure/docker/.env.dev --profile dev down --volumes && docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.override.yaml --env-file hub/infrastructure/docker/.env.dev --profile dev up -d --build",
    "hub:prod": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.prod.yaml --env-file hub/infrastructure/docker/.env.prod --profile prod up -d --build",
    "hub:staging": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.prod.yaml --env-file hub/infrastructure/docker/.env.staging --profile staging up -d --build",
    "hub:prod:down": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.prod.yaml --env-file hub/infrastructure/docker/.env.prod --profile prod down",
    "hub:staging:down": "docker compose -f hub/infrastructure/docker/compose.yaml -f hub/infrastructure/docker/compose.prod.yaml --env-file hub/infrastructure/docker/.env.staging --profile staging down",
    "// Profile": "---------------------------------------------",
    "profile:clean": "pnpm --filter @tupynambalucas/profile clean",
    "profile:generate": "pnpm --filter @tupynambalucas/profile generate",
    "profile:typecheck": "pnpm --filter @tupynambalucas/profile typecheck",
    "profile:lint": "pnpm --filter @tupynambalucas/profile lint",
    "// Studio / Checks": "---------------------------------------------",
    "studio:lint": "turbo run lint --filter=@tupynambalucas-studio/*",
    "studio:typecheck": "turbo run typecheck --filter=@tupynambalucas-studio/*",
    "// Studio / Bucket": "---------------------------------------------",
    "studio:bucket:lint": "pnpm --filter @tupynambalucas-studio/bucket lint",
    "studio:bucket:typecheck": "pnpm --filter @tupynambalucas-studio/bucket typecheck",
    "studio:bucket": "pnpm --filter @tupynambalucas-studio/bucket bucket",
    "// Studio / Penpot": "---------------------------------------------",
    "penpot:up": "pnpm --filter @tupynambalucas-studio/design penpot:up",
    "penpot:down": "pnpm --filter @tupynambalucas-studio/design penpot:down",
    "penpot:reset": "pnpm --filter @tupynambalucas-studio/design penpot:reset",
    "penpot:update": "pnpm --filter @tupynambalucas-studio/design penpot:update",
    "penpot:aide:up": "pnpm --filter @tupynambalucas-studio/design aide:up",
    "penpot:aide:down": "pnpm --filter @tupynambalucas-studio/design aide:down",
    "// Tools Context": "---------------------------------------------",
    "tools:lint": "turbo run lint --filter=@tupynambalucas-tools/*",
    "tools:typecheck": "turbo run typecheck --filter=@tupynambalucas-tools/*",
    "// Tools Turbo": "---------------------------------------------",
    "turborepo:devtools:up": "turbo devtools",
    "turborepo:devtools:down": "pnpm dlx kill-port 9876",
    "turborepo:up": "pnpm --filter @tupynambalucas-tools/turborepo cache:up",
    "turborepo:down": "pnpm --filter @tupynambalucas-tools/turborepo cache:down",
    "turborepo:reset": "pnpm --filter @tupynambalucas-tools/turborepo cache:reset",
    "turborepo:logs": "pnpm --filter @tupynambalucas-tools/turborepo cache:logs",
    "// Tools Mcp": "---------------------------------------------",
    "mcp:dev:up": "pnpm --filter @tupynambalucas-tools/mcp mcp:dev:up",
    "mcp:dev:down": "pnpm --filter @tupynambalucas-tools/mcp mcp:dev:down",
    "mcp:dev:reset": "pnpm --filter @tupynambalucas-tools/mcp mcp:dev:reset",
    "mcp:prod:up": "pnpm --filter @tupynambalucas-tools/mcp mcp:prod:up",
    "mcp:prod:down": "pnpm --filter @tupynambalucas-tools/mcp mcp:prod:down",
    "mcp:prod:reset": "pnpm --filter @tupynambalucas-tools/mcp mcp:prod:reset",
    "mcp:staging:up": "pnpm --filter @tupynambalucas-tools/mcp mcp:staging:up",
    "mcp:staging:down": "pnpm --filter @tupynambalucas-tools/mcp mcp:staging:down",
    "mcp:staging:reset": "pnpm --filter @tupynambalucas-tools/mcp mcp:staging:reset",
    "// Tools Agents": "---------------------------------------------",
    "agents:up": "pnpm --filter @tupynambalucas-tools/agents agents:up",
    "agents:down": "pnpm --filter @tupynambalucas-tools/agents agents:down",
    "agents:reset": "pnpm --filter @tupynambalucas-tools/agents agents:reset",
    "antigravity:up": "pnpm --filter @tupynambalucas-tools/agents antigravity:up",
    "antigravity:down": "pnpm --filter @tupynambalucas-tools/agents antigravity:down",
    "antigravity:reset": "pnpm --filter @tupynambalucas-tools/agents antigravity:reset",
    "copilot:up": "pnpm --filter @tupynambalucas-tools/agents copilot:up",
    "copilot:down": "pnpm --filter @tupynambalucas-tools/agents copilot:down",
    "copilot:reset": "pnpm --filter @tupynambalucas-tools/agents copilot:reset",
    "antigravity:auth": "pnpm --filter @tupynambalucas-tools/agents antigravity:auth",
    "copilot:auth": "pnpm --filter @tupynambalucas-tools/agents copilot:auth",
    "github:services:up": "pnpm --filter @tupynambalucas-tools/github github:services:up",
    "github:services:down": "pnpm --filter @tupynambalucas-tools/github github:services:down",
    "github:services:reset": "pnpm --filter @tupynambalucas-tools/github github:services:reset",
    "// CI/CD & Quality": "-------------------------------------------------",
    "format:check": "prettier --check --ignore-path shared/config/.prettierignore .",
    "format:write": "prettier --write --ignore-path shared/config/.prettierignore .",
    "version:changeset": "changeset",
    "version:bump": "changeset version",
    "version:publish": "changeset publish",
    "project:clear": "pnpm dlx npkill",
    "husky:test": "tsx tools/scripts/test-hooks.ts",
    "git:ignore-compiled-docs": "git update-index --skip-worktree CHANGELOG.md ROADMAP.md",
    "git:track-compiled-docs": "git update-index --no-skip-worktree CHANGELOG.md ROADMAP.md",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@tupynambalucas-shared/config": "workspace:*",
    "@changesets/cli": "catalog:",
    "@clack/prompts": "catalog:",
    "@eslint/compat": "catalog:tooling-stack",
    "@eslint/js": "catalog:tooling-stack",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:tooling-stack",
    "eslint": "catalog:tooling-stack",
    "eslint-config-prettier": "catalog:tooling-stack",
    "eslint-import-resolver-typescript": "catalog:tooling-stack",
    "eslint-plugin-import": "catalog:tooling-stack",
    "eslint-plugin-mdx": "catalog:tooling-stack",
    "eslint-plugin-prettier": "catalog:tooling-stack",
    "eslint-plugin-react": "catalog:web-stack",
    "eslint-plugin-react-hooks": "catalog:web-stack",
    "eslint-plugin-react-refresh": "catalog:web-stack",
    "husky": "catalog:",
    "kill-port": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:tooling-stack",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:tooling-stack",
    "wrangler": "catalog:"
  },
  "prettier": "@tupynambalucas-shared/config",
  "lint-staged": {
    "**/*.{js,mjs,ts,tsx,mdx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "**/*.{json,yaml,md,css,html}": [
      "prettier --write --ignore-path shared/config/.prettierignore"
    ]
  }
}
