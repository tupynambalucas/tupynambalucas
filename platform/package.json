  "description": "Tupynambá Lucas Tools Package",
  "license": "https://github.com/tupynambalucas/tupynambalucas/tree/main#license",
  "homepage": "https://github.com/tupynambalucas/tupynambalucas/tree/main/platform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tupynambalucas/tupynambalucas.git",
    "directory": "platform"
  },
  "scripts": {
    "platform:up": "docker compose -f infrastructure/docker/compose.yaml up -d --build",
    "platform:down": "docker compose -f infrastructure/docker/compose.yaml down",
    "platform:reset": "docker compose -f infrastructure/docker/compose.yaml down --volumes && docker compose -f infrastructure/docker/compose.yaml up -d --build"
  },
