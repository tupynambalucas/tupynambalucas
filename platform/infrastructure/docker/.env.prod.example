# ---------------------------------------------------------------- #
# PLATFORM SERVICES — PRODUCTION ENVIRONMENT (TEMPLATE)
# ---------------------------------------------------------------- #

# Environment configuration
DOCKER_ENV=prod
APP_ENV=prod
NODE_ENV=production

# ==========================================
# AGENTGATEWAY
# ==========================================
GATEWAY_PORT=8080

# ==========================================
# OPENTELEMETRY OBSERVABILITY
# ==========================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
GRAFANA_CLOUD_TOKEN=insert_grafana_cloud_token_here
SENTRY_OTLP_ENDPOINT=https://insert_sentry_dsn_here/integration/otlp
SENTRY_AUTH_HEADER=sentry sentry_key=insert_sentry_key_here

# ==========================================
# TURBOREPO REMOTE CACHE (turbocache)
# ==========================================
TURBO_CACHE_PORT=3008
PORT=3000
HOST=0.0.0.0
STORAGE_PROVIDER=local
STORAGE_PATH=/data
STORAGE_PATH_USE_TMP_FOLDER=false
TURBO_TOKEN=insert_secure_production_turborepo_token_here
AUTH_MODE=static
LOG_LEVEL=warn
ENABLE_STATUS_LOG=false
LOG_MODE=stdout
HTTP2=true
READ_ONLY=false
