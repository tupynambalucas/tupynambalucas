# ---------------------------------------------------------------- #
# PLATFORM SERVICES — ENVIRONMENT CONFIGURATION (TEMPLATE)
# ---------------------------------------------------------------- #

# Environment configuration
DOCKER_ENV=dev
APP_ENV=dev
NODE_ENV=development

# ==========================================
# OPENTELEMETRY OBSERVABILITY
# ==========================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
GRAFANA_CLOUD_OTLP_ENDPOINT=your_grafana_cloud_otlp_endpoint
GRAFANA_CLOUD_TOKEN=your_grafana_cloud_token
SENTRY_OTLP_ENDPOINT=your_sentry_otlp_endpoint
SENTRY_AUTH_HEADER=your_sentry_auth_header

# ==========================================
# TURBOREPO REMOTE CACHE (turbocache)
# ==========================================
TURBO_CACHE_PORT=3008
PORT=3000
HOST=0.0.0.0
STORAGE_PROVIDER=local
STORAGE_PATH=/data
STORAGE_PATH_USE_TMP_FOLDER=false
TURBO_TOKEN=your_remote_cache_token
AUTH_MODE=static
LOG_LEVEL=info
ENABLE_STATUS_LOG=true
LOG_MODE=stdout
HTTP2=false
READ_ONLY=false
