{
  "name": "@tupynambalucas/cortex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Tupynambá Lucas Varela Rodrigues <tupynambalucas.dev>",
  "description": "Tupynambá Lucas Unified AI Cortex Workspace",
  "license": "https://github.com/tupynambalucas/tupynambalucas/tree/main#license",
  "homepage": "https://github.com/tupynambalucas/tupynambalucas/tree/main/cortex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tupynambalucas/tupynambalucas.git",
    "directory": "cortex"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "eslint . --ext .ts",
    "cortex:core:up": "docker compose -f infrastructure/docker/compose.yaml --profile core up -d --build",
    "cortex:core:down": "docker compose -f infrastructure/docker/compose.yaml --profile core down",
    "cortex:core:reset": "docker compose -f infrastructure/docker/compose.yaml --profile core down --volumes && docker compose -f infrastructure/docker/compose.yaml --profile core up -d --build",
    "cortex:memory:up": "docker compose -f infrastructure/docker/compose.yaml --profile memory up -d --build",
    "cortex:memory:down": "docker compose -f infrastructure/docker/compose.yaml --profile memory down",
    "cortex:memory:reset": "docker compose -f infrastructure/docker/compose.yaml --profile memory down --volumes && docker compose -f infrastructure/docker/compose.yaml --profile memory up -d --build",
    "cortex:agents:up": "docker compose -f infrastructure/docker/compose.yaml --profile agents up -d --build",
    "cortex:agents:down": "docker compose -f infrastructure/docker/compose.yaml --profile agents down",
    "cortex:agents:reset": "docker compose -f infrastructure/docker/compose.yaml --profile agents down --volumes && docker compose -f infrastructure/docker/compose.yaml --profile agents up -d --build",
    "memory:dev": "kill-port 3006 9006 && turbo run dev --filter=@tupynambalucas-cortex-memory/*",
    "memory:build": "turbo run build --filter=@tupynambalucas-cortex-memory/*",
    "memory:start": "turbo run start --filter=@tupynambalucas-cortex-memory/*",
    "memory:preview": "turbo run preview --filter=@tupynambalucas-cortex-memory/*",
    "cortex:antigravity:auth": "podman exec -it agent-antigravity agy",
    "cortex:copilot:auth": "podman exec -it agent-copilot copilot login"
  },
  "dependencies": {},
  "devDependencies": {
    "@grpc/grpc-js": "catalog:api-stack",
    "@grpc/proto-loader": "catalog:api-stack"
  }
}
