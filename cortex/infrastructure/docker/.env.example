# ---------------------------------------------------------------- #
# CORTEX ECOSYSTEM — DEVELOPMENT ENVIRONMENT
# Centralized environment file for the unified AI Cortex stack.
# ---------------------------------------------------------------- #

DOCKER_ENV=dev
APP_ENV=dev
NODE_ENV=development

# ==========================================
# CORE INGRESS GATEWAY (agentgateway)
# ==========================================
GATEWAY_PORT=8080
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ==========================================
# CORE MEMORY (MongoDB Replica Set)
# ==========================================
MEMORY_MONGO_INITDB_ROOT_USERNAME=cortex_admin
MEMORY_MONGO_INITDB_ROOT_PASSWORD=cortex_password_dev
MEMORY_MONGO_INITDB_DATABASE=cortex_memory
MEMORY_MONGO_PORT=27018
MONGODB_URI=mongodb://cortex_admin:cortex_password_dev@127.0.0.1:27018/cortex_memory?authSource=admin&replicaSet=rs0&directConnection=true

# ==========================================
# MCP DATA PLANE SERVICES
# ==========================================
CONTEXT7_API_KEY=
FIRECRAWL_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
GRAFANA_CLOUD_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
PLAYWRIGHT_MCP_PORT=8080
PLAYWRIGHT_MCP_HOST=0.0.0.0
PLAYWRIGHT_MCP_BROWSER=chromium
PLAYWRIGHT_MCP_HEADLESS=true
PLAYWRIGHT_MCP_NO_SANDBOX=true
PLAYWRIGHT_MCP_ALLOWED_HOSTS=*

# ==========================================
# AI AGENT RUNTIMES (Control Plane)
# ==========================================
GEMINI_API_KEY=
GITHUB_TOKEN=
