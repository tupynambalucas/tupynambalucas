# ---------------------------------------------------------------- #
# CORTEX ECOSYSTEM — DEVELOPMENT ENVIRONMENT (TEMPLATE)
# Centralized environment template for the unified AI Cortex stack.
# ---------------------------------------------------------------- #

DOCKER_ENV=dev
APP_ENV=dev
NODE_ENV=development

# ==========================================
# CORE INGRESS GATEWAY (agentgateway)
# ==========================================
GATEWAY_PORT=8080
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ==========================================
# PERSISTENT MEMORY LAYER (neo4j)
# ==========================================
NEO4J_PASSWORD=your_neo4j_password_here

# ==========================================
# MCP DATA PLANE SERVICES
# ==========================================
CONTEXT7_API_KEY=your_context7_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
DOCKERHUB_PAT_TOKEN=your_dockerhub_pat_token_here
DOCKERHUB_USERNAME=your_dockerhub_username_here
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
GRAFANA_CLOUD_URL=your_grafana_url_here
GRAFANA_SERVICE_ACCOUNT_TOKEN=your_grafana_token_here

# ==========================================
# AI AGENT RUNTIMES (Control Plane)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
GITHUB_TOKEN=your_github_copilot_token_here
