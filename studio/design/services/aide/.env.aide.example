# ---------------------------------------------------------------- #
#  PENPOT Aide (AI Assistant) Service Config
# ---------------------------------------------------------------- #

# Secret key shared with backend for authentication
PENPOT_SECRET_KEY=your_penpot_secret_key

# Hostname the MCP server binds to
PENPOT_MCP_SERVER_HOST=your_penpot_mcp_server_host

# Network address the MCP server listens on
PENPOT_MCP_SERVER_LISTEN_ADDRESS=your_penpot_mcp_server_listen_address

# Hostname the MCP plugin server binds to
PENPOT_MCP_PLUGIN_SERVER_HOST=your_penpot_mcp_plugin_server_host

# Enable remote mode for the MCP server
PENPOT_MCP_REMOTE_MODE=your_penpot_mcp_remote_mode

# URL of the MCP server endpoint
PENPOT_MCP_SERVER_ADDRESS=your_penpot_mcp_server_address
