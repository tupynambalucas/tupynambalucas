# ---------------------------------------------------------------- #
#  PENPOT Backend Config
# ---------------------------------------------------------------- #

# Public-facing URI for the Penpot application
PENPOT_PUBLIC_URI=your_penpot_public_uri

# Database Connection
# PostgreSQL connection URI
PENPOT_DATABASE_URI=your_penpot_database_uri
# Database username for authentication
PENPOT_DATABASE_USERNAME=your_penpot_database_username
# Database password for authentication
PENPOT_DATABASE_PASSWORD=your_penpot_database_password

# S3 Bucket Configuration (Cloud)
# Storage backend type (e.g., s3 or fs)
PENPOT_OBJECTS_STORAGE_BACKEND=your_penpot_objects_storage_backend
# S3-compatible endpoint URL
PENPOT_OBJECTS_STORAGE_S3_ENDPOINT=your_penpot_objects_storage_s3_endpoint
# S3 bucket name for storing design objects
PENPOT_OBJECTS_STORAGE_S3_BUCKET=your_penpot_objects_storage_s3_bucket
# S3 region identifier
PENPOT_OBJECTS_STORAGE_S3_REGION=your_penpot_objects_storage_s3_region
# Force path-style addressing for S3-compatible services
PENPOT_OBJECTS_STORAGE_S3_FORCE_PATH_STYLE=your_penpot_objects_storage_s3_force_path_style
# AWS (or S3-compatible) access key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS (or S3-compatible) secret access key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
