{
  "name": "@tupynambalucas-studio/design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Tupynambá Lucas Varela Rodrigues <tupynambalucas.dev>",
  "description": "tupynambalucas.dev Studio Package",
  "license": "https://github.com/tupynambalucas/tupynambalucas/tree/main#license",
  "homepage": "https://github.com/tupynambalucas/tupynambalucas/tree/main/studio/assets#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tupynambalucas/tupynambalucas.git",
    "directory": "studio/assets"
  },
  "files": [
    "assets"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./assets-manifest.json": "./assets/assets-manifest.json",
    "./icons": "./assets/icons/index.tsx",
    "./logos": "./assets/brand/logos/index.ts",
    "./logos/*": "./assets/brand/logos/*",
    "./three/*": "./assets/three/*",
    "./images/*": "./assets/images/*",
    "./brand/*": "./assets/brand/*",
    "./tokens": "./assets/tokens/index.ts",
    "./tokens.css": "./assets/tokens/tokens.css",
    "./theme.css": "./assets/tokens/theme.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "penpot:up": "podman compose -f infrastructure/docker/compose.yaml --profile penpot up -d",
    "penpot:down": "podman compose -f infrastructure/docker/compose.yaml --profile penpot down",
    "penpot:reset": "podman compose -f infrastructure/docker/compose.yaml --profile penpot down --volumes && podman compose -f infrastructure/docker/compose.yaml --profile penpot up -d",
    "memos:up": "podman compose -f infrastructure/docker/compose.yaml --profile memos up -d",
    "memos:down": "podman compose -f infrastructure/docker/compose.yaml --profile memos down",
    "memos:reset": "podman compose -f infrastructure/docker/compose.yaml --profile memos down --volumes && podman compose -f infrastructure/docker/compose.yaml --profile memos up -d"
  },
  "dependencies": {
    "react": "catalog:web-stack",
    "react-dom": "catalog:web-stack",
    "react-icons": "catalog:studio-stack"
  },
  "devDependencies": {
    "@tupynambalucas-shared/config": "workspace:*",
    "@types/react": "catalog:web-stack",
    "@types/react-dom": "catalog:web-stack",
    "tailwindcss": "catalog:shared-stack",
    "typescript": "catalog:"
  }
}
