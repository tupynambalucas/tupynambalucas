# ---------------------------------------------------------------- #
# STUDIO DESIGN WORKSPACE — ENVIRONMENT CONFIGURATION (EXAMPLE)
# ---------------------------------------------------------------- #

# Global Orchestration Configuration
ENVIRONMENT=dev
APP_ENV=dev
TAG=local

# ==========================================
# LAYERED SERVICE: PENPOT DESIGN SYSTEM
# ==========================================
PENPOT_VERSION=2.16.2
PENPOT_FLAGS=disable-email-verification disable-secure-session-cookies
PENPOT_REDIS_URI=redis://valkey/0
PENPOT_SECRET_KEY=your_penpot_secret_key

# Frontend Service
PENPOT_BACKEND_URI=http://backend:6060
PENPOT_EXPORTER_URI=http://exporter:6061
PENPOT_FRONTEND_PORT=9005

# Backend Service
PENPOT_PUBLIC_URI=http://localhost:9005
PENPOT_DATABASE_URI=postgresql://your_db_user:your_db_password@your_db_host/your_db_name
PENPOT_DATABASE_USERNAME=penpot_app
PENPOT_DATABASE_PASSWORD=your_db_password

# Cloudflare R2 Storage (Penpot Backed)
PENPOT_OBJECTS_STORAGE_BACKEND=s3
PENPOT_OBJECTS_STORAGE_S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
PENPOT_OBJECTS_STORAGE_S3_BUCKET=your_bucket_name
PENPOT_OBJECTS_STORAGE_S3_REGION=auto
PENPOT_OBJECTS_STORAGE_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Exporter Service
PENPOT_EXPORTER_PUBLIC_URI=http://frontend:8080

# Aide AI Assistant
PENPOT_MCP_SERVER_HOST=0.0.0.0
PENPOT_MCP_SERVER_LISTEN_ADDRESS=0.0.0.0
PENPOT_MCP_PLUGIN_SERVER_HOST=0.0.0.0
PENPOT_MCP_REMOTE_MODE=true
PENPOT_MCP_SERVER_ADDRESS=http://localhost:4401
PENPOT_AIDE_PORT_4400=4400
PENPOT_AIDE_PORT_4401=4401
PENPOT_AIDE_PORT_4402=4402
PENPOT_AIDE_PORT_4403=4403

# ==========================================
# LAYERED SERVICE: MEMOS COLLABORATIVE NOTES
# ==========================================
MEMOS_PORT=5230
MEMOS_DRIVER=postgres
MEMOS_DSN=postgresql://your_db_user:your_db_password@your_db_host/your_db_name
