# ================================================================= #
# PENPOT -- DESIGN STUDIO DEVELOPMENT ENVIRONMENT (EXAMPLE)
# ================================================================= #

# ----------------------------------------------------------------- #
# GLOBAL / ORCHESTRATION SETTINGS
# ----------------------------------------------------------------- #
# Application runtime environment identifier
ENVIRONMENT=dev
# Application environment mode
APP_ENV=dev
# Docker image tag used for deployments
TAG=local

# Flags shared by Backend and Frontend
PENPOT_FLAGS=disable-email-verification disable-secure-session-cookies

# Redis URI shared by Backend and Exporter
PENPOT_REDIS_URI=redis://valkey/0

# Secret Key shared by Backend, Exporter and Aide
PENPOT_SECRET_KEY=your_penpot_secret_key

# ----------------------------------------------------------------- #
# SERVICE: FRONTEND
# ----------------------------------------------------------------- #
# Internal URI for the backend API service
PENPOT_BACKEND_URI=http://backend:6060
# Internal URI for the exporter service
PENPOT_EXPORTER_URI=http://exporter:6061
# Port exposed by frontend service to host
PENPOT_FRONTEND_PORT=9005

# ----------------------------------------------------------------- #
# SERVICE: BACKEND
# ----------------------------------------------------------------- #
# Public-facing URI for the Penpot application
PENPOT_PUBLIC_URI=http://localhost:9005
# PostgreSQL connection URI
PENPOT_DATABASE_URI=your_penpot_database_uri
# Database username for authentication
PENPOT_DATABASE_USERNAME=your_penpot_database_username
# Database password for authentication
PENPOT_DATABASE_PASSWORD=your_penpot_database_password

# S3 Bucket Configuration (Cloud)
# Storage backend type (e.g., s3 or fs)
PENPOT_OBJECTS_STORAGE_BACKEND=s3
# S3-compatible endpoint URL
PENPOT_OBJECTS_STORAGE_S3_ENDPOINT=your_penpot_objects_storage_s3_endpoint
# S3 bucket name for storing design objects
PENPOT_OBJECTS_STORAGE_S3_BUCKET=your_penpot_objects_storage_s3_bucket
# S3 region identifier
PENPOT_OBJECTS_STORAGE_S3_REGION=your_penpot_objects_storage_s3_region
# Force path-style addressing for S3-compatible services
PENPOT_OBJECTS_STORAGE_S3_FORCE_PATH_STYLE=true
# AWS (or S3-compatible) access key ID
AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS (or S3-compatible) secret access key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ----------------------------------------------------------------- #
# SERVICE: EXPORTER
# ----------------------------------------------------------------- #
# Internal URI used by the exporter to reach the frontend service
PENPOT_EXPORTER_PUBLIC_URI=http://frontend:8080

# ----------------------------------------------------------------- #
# SERVICE: AIDE (AI ASSISTANT)
# ----------------------------------------------------------------- #
# Hostname the MCP server binds to
PENPOT_MCP_SERVER_HOST=0.0.0.0
# Network address the MCP server listens on
PENPOT_MCP_SERVER_LISTEN_ADDRESS=0.0.0.0
# Hostname the MCP plugin server binds to
PENPOT_MCP_PLUGIN_SERVER_HOST=0.0.0.0
# Enable remote mode for the MCP server
PENPOT_MCP_REMOTE_MODE=true
# URL of the MCP server endpoint
PENPOT_MCP_SERVER_ADDRESS=http://localhost:4401

# Ports exposed by aide service to host
PENPOT_AIDE_PORT_4400=4400
PENPOT_AIDE_PORT_4401=4401
PENPOT_AIDE_PORT_4402=4402
PENPOT_AIDE_PORT_4403=4403
