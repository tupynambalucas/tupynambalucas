{
  "extends": "@tupynambalucas-shared/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "allowArbitraryExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@features/*": ["./src/features/*"],
      "@domains/*": ["./src/domains/*"],
      /* Desenvolvimento instantâneo: lê a fonte do core */
      "@tupynambalucas-hub/core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/types/**/*.d.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
