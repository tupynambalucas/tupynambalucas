# ================================================================= #
# ELO ORGANICO — INSTANCE ORCHESTRATION DEVELOPMENT ENVIRONMENT TEMPLATE
# ================================================================= #

# ----------------------------------------------------------------- #
# GLOBAL / ORCHESTRATION SETTINGS
# ----------------------------------------------------------------- #
ENVIRONMENT=dev
APP_ENV=dev
TAG=local
NODE_ENV=development

# ----------------------------------------------------------------- #
# SERVICE: DATABASE (MONGODB)
# ----------------------------------------------------------------- #
MONGO_PORT=27017
MONGO_USER=EloInstance
MONGO_PASSWORD=
MONGO_DB_NAME=elo_instance_db

# ----------------------------------------------------------------- #
# SERVICE: CACHE / QUEUES (REDIS)
# ----------------------------------------------------------------- #
REDIS_PORT=6379
REDIS_HOST=localhost

# ----------------------------------------------------------------- #
# SERVICE: BACKEND (FASTIFY API)
# ----------------------------------------------------------------- #
SERVER_PORT=3000
SERVER_HOST=localhost

MONGO_URI=mongodb://EloInstance:[PASSWORD]@localhost:27017/elo_instance_db?authSource=admin&replicaSet=rs0&directConnection=true

JWT_SECRET=
SESSION_SECRET=
USER_SESSION_KEY=EloInstance

ADMIN_USER_SEED=admin
ADMIN_EMAIL_SEED=tupynambalucas@gmail.com
ADMIN_PASS_SEED=admin

SENTRY_DSN=
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ----------------------------------------------------------------- #
# SERVICE: FRONTEND (REACT / VITE WEB)
# ----------------------------------------------------------------- #
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
VITE_CLOUDINARY_CLOUD_NAME=tupynambalucas
