# ================================================================= #
# ELO ORGANICO -- INSTANCE ORCHESTRATION PRODUCTION ENVIRONMENT
# ================================================================= #

# ----------------------------------------------------------------- #
# GLOBAL / ORCHESTRATION SETTINGS
# ----------------------------------------------------------------- #
# Application runtime environment identifier
ENVIRONMENT=your_environment
# Application environment mode
APP_ENV=your_app_env
# Docker image tag used for deployments
TAG=your_docker_image_tag
# Node.js runtime environment mode
NODE_ENV=your_node_env

# ----------------------------------------------------------------- #
# SERVICE: CACHE / QUEUES (REDIS)
# ----------------------------------------------------------------- #
# Redis server hostname
REDIS_HOST=your_redis_host
# Redis server port
REDIS_PORT=your_redis_port
# Redis connection URL used by services
REDIS_URL=your_redis_url

# ----------------------------------------------------------------- #
# SERVICE: BACKEND (FASTIFY API)
# ----------------------------------------------------------------- #
# Fastify HTTP server port
SERVER_PORT=your_server_port
# Fastify HTTP server bind address
SERVER_HOST=your_server_host

# Full MongoDB Atlas connection URI for the production cluster
MONGO_URI=your_full_mongo_connection_uri

# Secret key used to sign and verify JSON Web Tokens
JWT_SECRET=your_jwt_secret
# Secret key used to sign server-side session cookies
SESSION_SECRET=your_session_secret
# Key used to store user session data
USER_SESSION_KEY=your_user_session_key

# Default admin username created during database seeding
ADMIN_USER_SEED=your_admin_username
# Default admin email created during database seeding
ADMIN_EMAIL_SEED=your_admin_email
# Default admin password created during database seeding
ADMIN_PASS_SEED=your_admin_password

# Sentry DSN for error tracking and monitoring
SENTRY_DSN=your_sentry_dsn
# Cloudflare Turnstile server-side secret key for bot protection
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ----------------------------------------------------------------- #
# SERVICE: FRONTEND (REACT / VITE WEB)
# ----------------------------------------------------------------- #
# Cloudflare Turnstile client-side site key for bot protection widget
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
# Cloudinary cloud name for media asset delivery
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
