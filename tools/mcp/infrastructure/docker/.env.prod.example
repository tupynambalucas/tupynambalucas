# ---------------------------------------------------------------- #
# MCP ECOSYSTEM — PRODUCTION ENVIRONMENT
# Docker Compose environment for production MCP gateway deployment.
# ---------------------------------------------------------------- #

# Docker environment identifier
DOCKER_ENV=prod

# Application runtime environment
APP_ENV=prod

# Port exposed by the MCP gateway service
GATEWAY_PORT=your_gateway_port

# APISIX — Admin API key for the Apache APISIX gateway
APISIX_ADMIN_KEY=your_apisix_admin_key

# Context7 MCP — API key for the Context7 documentation service
CONTEXT7_API_KEY=your_context7_api_key

# Browser / Playwright MCP — Rewrite localhost URLs for container networking
BROWSER_REWRITE_LOCALHOST=true

# Firecrawl MCP — API key for the Firecrawl web scraping service
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Docker Hub MCP — Personal access token for Docker Hub API
DOCKERHUB_PAT_TOKEN=your_dockerhub_pat_token

# Docker Hub MCP — Docker Hub account username
DOCKERHUB_USERNAME=your_dockerhub_username

# GitHub MCP — Personal access token for GitHub API
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_personal_access_token
