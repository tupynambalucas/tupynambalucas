# Common Environment Variables (Shared by both Git and GitHub CLI)
# ==============================================================================

# GitHub Personal Access Token (PAT) used by both environments for authentication
GH_TOKEN=your_github_personal_access_token

# Target GitHub Repository (owner/repo format) used by the GitHub CLI
GH_REPO=your_github_repository

# Git author details used inside the git-bash container
GIT_AUTHOR_NAME=your_git_author_name
GIT_AUTHOR_EMAIL=your_git_author_email

# Git committer details used inside the git-bash container (falls back to author)
GIT_COMMITTER_NAME=your_git_committer_name
GIT_COMMITTER_EMAIL=your_git_committer_email

# Directory path for storing secrets and security configuration files
SECRETS_DIR=your_secrets_dir

# Directory path for storing script execution logs
LOG_DIR=your_log_dir

# Default text editor for authoring commit messages (Git) and PR descriptions (gh)
EDITOR=your_editor

# Default paging program to send multi-page output to
PAGER=your_pager
