# Common Environment Variables (Shared by both Git and GitHub CLI)
# ==============================================================================
# Copy this file to '.env' in the same directory and fill in your actual values.
# Do NOT commit the '.env' file containing your personal tokens to version control.

# GitHub Personal Access Token (PAT) used by both environments for authentication
GH_TOKEN=your_github_personal_access_token

# Fallback token for Docker Compose environment variables mapping (compatibility)
DNS_REGISTRY_PAT=your_github_personal_access_token

# Default text editor for authoring commit messages (Git) and PR descriptions (gh)
EDITOR=nano

# Default paging program to send multi-page output to
PAGER=less
