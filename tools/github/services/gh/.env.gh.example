# GitHub CLI Specific Environment Variables
# ==============================================================================

# Target GitHub Repository (owner/repo format) used by the GitHub CLI
GH_REPO=your-owner/your-repo
GIT_AUTHOR_NAME=your-name
GIT_AUTHOR_EMAIL=your-email@example.com

# Git committer details used inside the git-bash container (falls back to author)
GIT_COMMITTER_NAME=your-name
GIT_COMMITTER_EMAIL=your-email@example.com
# Disable telemetry data collection
GH_TELEMETRY=disabled

# Disable interactive prompts during commands execution (prevents hangs in automated tasks)
GH_PROMPT_DISABLED=true

# Disable GitHub CLI update notifications
GH_NO_UPDATE_NOTIFIER=true
