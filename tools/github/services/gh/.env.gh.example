# GitHub CLI Specific Environment Variables
# ==============================================================================

# Disable telemetry data collection
GH_TELEMETRY=your_gh_telemetry

# Disable interactive prompts during commands execution (prevents hangs in automated tasks)
GH_PROMPT_DISABLED=your_gh_prompt_disabled

# Disable GitHub CLI update notifications
GH_NO_UPDATE_NOTIFIER=your_gh_no_update_notifier
