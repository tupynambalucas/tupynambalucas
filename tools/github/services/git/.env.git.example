# Git Command Line Specific Environment Variables
# ==============================================================================

# Git author details used inside the git-bash container
GIT_AUTHOR_NAME=your-name
GIT_AUTHOR_EMAIL=your-email@example.com

# Git committer details used inside the git-bash container (falls back to author)
GIT_COMMITTER_NAME=your-name
GIT_COMMITTER_EMAIL=your-email@example.com

# Disable terminal prompts (prevents hangs if an authentication prompt appears)
GIT_TERMINAL_PROMPT=0

# Configure Git to automatically authenticate HTTPS requests to github.com using the GH_TOKEN
GIT_CONFIG_COUNT=2
GIT_CONFIG_KEY_0=credential.https://github.com.username
GIT_CONFIG_VALUE_0=x-access-token
GIT_CONFIG_KEY_1=credential.https://github.com.helper
GIT_CONFIG_VALUE_1=!f() { test "$1" = get && echo "password=${GH_TOKEN}"; }; f

# Default text editor and pager
EDITOR=nano
PAGER=less
