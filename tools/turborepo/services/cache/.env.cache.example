# ---------------------------------------------------------------- #
# TURBOREPO REMOTE CACHE — SERVICE CONFIGURATION
# Environment variables for the Turborepo remote cache Docker service.
# ---------------------------------------------------------------- #

# ==========================================
# REQUIRED CONFIGURATION FOR LOCAL DOCKER CACHE
# ==========================================

# Server — Port the cache service listens on
PORT=your_port

# Server — Host address the cache service binds to
HOST=your_host

# Storage — Backend provider for cached artifacts (local or s3)
STORAGE_PROVIDER=your_storage_provider

# Storage — Filesystem path where cached artifacts are stored
STORAGE_PATH=your_storage_path

# Storage — Disable the tmp prefix so it writes exactly to /data (where the volume is mounted)
STORAGE_PATH_USE_TMP_FOLDER=false

# Authentication — Secret token used by the Turborepo CLI (must match TURBO_TOKEN in client)
TURBO_TOKEN=your_turbo_token

# Authentication — Mode for verifying client tokens (static or jwt)
AUTH_MODE=your_auth_mode

# ==========================================
# OPTIONAL CONFIGURATIONS
# ==========================================

# JWT — URL for fetching JSON Web Key Sets (used when AUTH_MODE=jwt)
# JWKS_URL=

# JWT — Expected token issuer claim
# JWT_ISSUER=

# JWT — Expected token audience claim
# JWT_AUDIENCE=

# JWT — Required scopes for read operations
# JWT_READ_SCOPES=

# JWT — Required scopes for write operations
# JWT_WRITE_SCOPES=

# Logging — Verbosity level (debug, info, warn, error)
LOG_LEVEL=your_log_level

# Logging — Enable periodic status log output
ENABLE_STATUS_LOG=true

# Logging — Output destination (stdout or file)
LOG_MODE=your_log_mode

# Logging — Path to log file (used when LOG_MODE=file)
# LOG_FILE=

# Server — Maximum request body size limit
# BODY_LIMIT=

# Server — Enable HTTP/2 protocol support
HTTP2=false

# SSL — Path to the private key file for HTTPS
# SSL_KEY_PATH=

# SSL — Path to the certificate file for HTTPS
# SSL_CERT_PATH=

# Cache — Signing key for verifying cached artifact integrity
# TURBO_REMOTE_CACHE_SIGNATURE_KEY=

# Cache — Enable read-only mode (disables writes to the cache)
READ_ONLY=false
