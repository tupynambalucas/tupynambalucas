# ---------------------------------------------------------------- #
# MONITOR STACK — DEVELOPMENT ENVIRONMENT
# Docker Compose environment for local observability stack.
# ---------------------------------------------------------------- #

# Application runtime environment
APP_ENV=dev

# ==========================================
# CLOUD OBSERVABILITY (SaaS)
# ==========================================

# Grafana Cloud — OTLP gateway endpoint for ingesting metrics and traces
# Create an account at grafana.com and retrieve your OTLP credentials
GRAFANA_CLOUD_OTLP_ENDPOINT=your_grafana_cloud_otlp_endpoint

# Grafana Cloud — Base64-encoded authentication token for OTLP ingestion
GRAFANA_CLOUD_TOKEN=your_grafana_cloud_token

# Sentry — OTLP endpoint for forwarding error traces and crash reports
# Create a project in Sentry and retrieve the DSN
SENTRY_OTLP_ENDPOINT=your_sentry_otlp_endpoint

# Sentry — Authentication header containing the Sentry client key
SENTRY_AUTH_HEADER=your_sentry_auth_header
