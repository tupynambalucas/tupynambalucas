# ---------------------------------------------------------------- #
# MONITOR STACK — PRODUCTION ENVIRONMENT
# Docker Compose environment for production observability stack.
# ---------------------------------------------------------------- #

# Application runtime environment
APP_ENV=prod

# Grafana — Admin dashboard username
GRAFANA_ADMIN_USER=your_grafana_admin_user

# Grafana — Admin dashboard password
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password

# Grafana — Port exposed by the Grafana web interface
GRAFANA_PORT=your_grafana_port
